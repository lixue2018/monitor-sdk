{
    "name": "monitor-sdk",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
      "packages/core",
      "packages/vue"
    ],
    "scripts": {
      "build": "npm run build --workspaces --if-present",
      "build:core": "npm run build -w @lixue2018/monitorx-core",
      "build:vue": "npm run build -w @lixue2018/monitorx-vue",
      "publish:core": "cd packages/core && npm publish --access public",
      "publish:vue": "cd packages/vue && npm publish --access public",
      "publish:all": "npm run build && npm run publish:core && npm run publish:vue"
    }
  }